default_platform(:ios)

platform :ios do
  desc "Sign the Unity Xcode export and upload to TestFlight"
  lane :beta do
    setup_ci

    app_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      in_house: false
    )

    match(
      type: "appstore",
      api_key: api_key,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTH"],
      readonly: false
    )

    xcodeproj = Dir["build/iOS/**/Unity-iPhone.xcodeproj"].first
    UI.user_error!("Unity-iPhone.xcodeproj not found under build/iOS") unless xcodeproj

    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][app_id]

    update_code_signing_settings(
      path: xcodeproj,
      use_automatic_signing: false,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      bundle_identifier: app_id,
      profile_name: profile_name,
      targets: ["Unity-iPhone"]
    )

    info_plist = File.join(File.dirname(xcodeproj), "Info.plist")
    set_info_plist_value(path: info_plist, key: "CFBundleVersion", value: ENV.fetch("GITHUB_RUN_NUMBER", "1"))
    set_info_plist_value(path: info_plist, key: "ITSAppUsesNonExemptEncryption", value: false)

    build_app(
      project: xcodeproj,
      scheme: "Unity-iPhone",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { app_id => profile_name }
      },
      output_directory: "build/output",
      output_name: "BrawlArena"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
