  roster:
  - id: aria
    displayName: Aria
    role: Twin-Blade Duelist
    description: A whirlwind of arcane steel. Aria darts between enemies and shreds
      them up close with fast twin-sword combos before they can react.
    portrait: {fileID: 21300000, guid: 84889db8ff44b89418edaf3c24473e38, type: 3}
    prefab: {fileID: 1394585723079213298, guid: fd61d790259cf9746a7fbe63f3b70d98, type: 3}
