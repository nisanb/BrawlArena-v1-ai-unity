  - id: nova
    displayName: Nova
    role: Storm Mage
    description: "Fragile but ferocious. Nova rains storm bolts from long range \u2014
      keep your distance, keep casting, and never let them close the gap."
    portrait: {fileID: 21300000, guid: 6c98d08bb5c43864297dd774d96f299f, type: 3}
