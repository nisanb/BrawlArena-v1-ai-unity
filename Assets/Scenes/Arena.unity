  - id: vex
    displayName: Vex
    role: Shadow Skirmisher
    description: Strike from the dark. Vex slips along the arena's edges, ambushes
      stragglers with shadow blades, and vanishes before help arrives.
    portrait: {fileID: 21300000, guid: 485124da1ef0a9440abd6b238f9c657d, type: 3}
