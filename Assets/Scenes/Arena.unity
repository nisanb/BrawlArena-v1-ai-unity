  - id: grimm
    displayName: Grimm
    role: Greatsword Bruiser
    description: "Slow wind-up, devastating payoff. Grimm's flaming greatsword hits
      harder than anything in the arena \u2014 every swing has to count."
    portrait: {fileID: 21300000, guid: 6a07a75cc2f1b364fb23b7b6ad783996, type: 3}
